          {
            "type": "command",
            "command": "if [ -d ./analysis ]; then bash .claude/skills/dfir-bootstrap/audit.sh \"stop_hook\" \"Claude session ended\" \"review prior audit entries and ./analysis/<domain>/findings.md for context\" >/dev/null 2>&1 || true; fi"
